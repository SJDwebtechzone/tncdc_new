generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SiteSettings {
  id             Int      @id @default(autoincrement())
  headerType     String   @default("logo")
  logo           String   @default("")
  favicon        String   @default("")
  websiteUrl     String   @default("")
  playStoreLink  String   @default("")
  appStoreLink   String   @default("")
  primaryColor   String   @default("#10b981")
  secondaryColor String   @default("#059669")
  marqueeEntries String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model InstituteProfile {
  id                     Int      @id @default(1)
  instituteName          String   @default("")
  ownerName              String   @default("")
  designation            String   @default("DIRECTOR")
  email                  String   @default("")
  dob                    String   @default("")
  mobile                 String   @default("")
  alternateMobile        String   @default("")
  address                String   @default("")
  state                  String   @default("Tamil Nadu")
  city                   String   @default("")
  pincode                String   @default("")
  controllerName         String   @default("")
  showController         Boolean  @default(false)
  showDirector           Boolean  @default(false)
  logoUrl                String   @default("")
  signatureUrl           String   @default("")
  controllerSignatureUrl String   @default("")
  updatedAt              DateTime @updatedAt

  @@map("institute_profile")
}

model CourseCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  iconUrl   String?
  count     Int      @default(0)
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  courses   Course[]

  @@map("course_categories")
}

model CourseAwardCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  courses   Course[]

  @@map("course_award_categories")
}

model Course {
  id              Int      @id @default(autoincrement())
  title           String
  awardCategoryId Int
  certificateType String   @default("Certificate")
  preposition     String   @default("In")
  courseType      String
  categoryId      Int
  mrp             Float?
  price           Float?
  duration        String
  durationUnit    String   @default("Months")
  imageUrl        String?
  previewVideoUrl String?
  totalLectures   Int?
  practicalExam   Boolean  @default(true)
  objectiveExam   Boolean  @default(true)
  description     String?
  syllabus        String?
  tags            String[] @default([])
  isPopular       Boolean  @default(true)
  isRecommended   Boolean  @default(true)
  isMRPVisible    Boolean  @default(true)
  hideExamResult  Boolean  @default(true)
  status          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  courseCode      String   @unique

  // Dynamic Metrics
  rating Float @default(0)
  likes  Int   @default(0)
  views  Int   @default(0)

  // New Exam Configuration Fields
  totalMarks        Int?   @default(100)
  objectiveMarks    Int?   @default(50)
  practicalMarks    Int?   @default(50)
  totalQuestions    Int?   @default(0)
  marksPerQuestion  Float? @default(0)
  examTiming        Int?   @default(0) // in minutes
  passingPercentage Int?   @default(35)

  awardCategory  CourseAwardCategory @relation(fields: [awardCategoryId], references: [id])
  category       CourseCategory      @relation(fields: [categoryId], references: [id])
  courseSubjects CourseSubject[]
  semesters      CourseSemester[]
  videos         CourseVideo[]
  notes          CourseNote[]
  onlineClasses  OnlineClass[]

  @@map("courses")
}

model CourseSemester {
  id       Int    @id @default(autoincrement())
  courseId Int
  name     String
  order    Int    @default(1)

  course   Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  subjects CourseSubject[]
  videos   CourseVideo[]
  notes    CourseNote[]

  @@map("course_semesters")
}

model CourseSubject {
  id         Int  @id @default(autoincrement())
  courseId   Int
  subjectId  Int
  semesterId Int?
  order      Int  @default(1)

  // Per-subject exam settings
  totalMarks        Int?
  passingPercentage Int?
  objectiveMarks    Int?
  practicalMarks    Int?
  totalQuestions    Int?
  marksPerQuestion  Float?
  examTiming        Int? // in minutes

  course   Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  subject  Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  semester CourseSemester? @relation(fields: [semesterId], references: [id], onDelete: Cascade)

  @@map("course_subjects")
}

model CourseVideo {
  id         Int    @id @default(autoincrement())
  title      String
  videoUrl   String
  courseId   Int
  subjectId  Int
  semesterId Int?

  course   Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  subject  Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  semester CourseSemester? @relation(fields: [semesterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("course_videos")
}

model CourseNote {
  id         Int    @id @default(autoincrement())
  title      String
  fileUrl    String
  courseId   Int
  subjectId  Int
  semesterId Int?

  course   Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  subject  Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  semester CourseSemester? @relation(fields: [semesterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("course_notes")
}

model Batch {
  id              Int      @id @default(autoincrement())
  name            String
  fromTime        String
  toTime          String
  timing          String
  totalStudents   String
  totalAmount     String   @default("18,000.00")
  paidAmount      String   @default("0.00")
  remainingAmount String   @default("18,000.00")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("batches")
}

model Designation {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("designations")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  permissions Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("roles")
}

model User {
  id                  Int                 @id @default(autoincrement())
  email               String              @unique
  password            String
  fullName            String              @default("")
  mobile              String              @default("")
  employeeId          String              @default("")
  dateOfJoining       String              @default("")
  department          String              @default("")
  designation         String              @default("")
  qualification       String              @default("")
  dateOfBirth         String              @default("")
  address             String              @default("")
  profilePhoto        String              @default("")
  roles               String[]            @default([])
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  emergencyContact    String              @default("")
  paidLeaveAllocation Int                 @default(12)
  salaryMode          String              @default("Monthly")
  basicSalary         Float               @default(0)
  status              Boolean             @default(true)
  attendance          StaffAttendance[]
  leaves              StaffLeave[]
  lectures            StaffLecture[]
  salaries            StaffSalaryRecord[]

  @@map("users")
}

model StudentAttendance {
  id          Int       @id @default(autoincrement())
  admissionId Int
  admission   Admission @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  date        String
  batch       String?
  punchIn     String?
  punchOut    String?
  status      String // Present, Absent, Leave
  remarks     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("student_attendance")
}

model Enquiry {
  id              Int               @id @default(autoincrement())
  firstName       String
  relationship    String
  parentName      String?
  surname         String?
  dob             String
  gender          String
  pincode         String
  mobile          String
  alternateMobile String?
  email           String?
  address         String?
  course          String
  source          String            @default("Unknown")
  assignedTo      String            @default("Unassigned")
  profileImage    String?
  signature       String?
  motherName      String?
  maritalStatus   String?           @default("Single")
  qualification   String?
  cast            String?
  state           String?           @default("Tamil Nadu")
  city            String?
  status          String            @default("New")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  followUps       EnquiryFollowUp[]
  admission       Admission?

  @@map("enquiries")
}

model EnquiryFollowUp {
  id                  Int      @id @default(autoincrement())
  enquiryId           Int
  followUpDate        String
  nextFollowUpDate    String?
  studentResponse     String
  conversationDetails String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  enquiry             Enquiry  @relation(fields: [enquiryId], references: [id], onDelete: Cascade)

  @@map("enquiry_follow_ups")
}

model ExamGrade {
  id          Int      @id @default(autoincrement())
  performance String
  grade       String
  start       Int
  end         Int
  updatedAt   DateTime @updatedAt

  @@map("exam_grades")
}

model WebsiteBanner {
  id          Int      @id @default(autoincrement())
  displayMode String   @default("banner")
  badgeText   String   @default("")
  badgeIcon   String   @default("")
  title       String   @default("")
  description String   @default("")
  imageUrl    String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("website_banners")
}

model FAQ {
  id        Int      @id @default(autoincrement())
  question  String
  answer    String
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faqs")
}

model FAQBanner {
  id        Int      @id @default(1)
  banner1   String   @default("")
  banner2   String   @default("")
  updatedAt DateTime @updatedAt

  @@map("faq_banners")
}

model Teacher {
  id           Int                 @id @default(autoincrement())
  name         String
  image        String
  designation  String?
  description  String?
  facebookUrl  String?
  twitterUrl   String?
  instagramUrl String?
  phone        String?
  email        String?
  basicSalary  Float               @default(0)
  attendance   StaffAttendance[]
  salaries     StaffSalaryRecord[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@map("teachers")
}

model Testimonial {
  id        Int      @id @default(autoincrement())
  name      String
  image     String?
  role      String?
  institute String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("testimonials")
}

model TestimonialSettings {
  id        Int      @id @default(1)
  title     String   @default("")
  subtitle  String   @default("")
  updatedAt DateTime @updatedAt

  @@map("testimonial_settings")
}

model MissionVision {
  id                   Int      @id @default(1)
  bannerBadgeText      String   @default("")
  bannerBadgeIcon      String   @default("")
  bannerDesc           String   @default("")
  videoImage           String   @default("")
  videoUrl             String   @default("")
  visionTitle          String   @default("")
  visionDesc           String   @default("")
  visionImage1         String   @default("")
  visionImage2         String   @default("")
  visionImage3         String   @default("")
  visionFeature1Icon   String   @default("")
  visionFeature1Title  String   @default("")
  visionFeature1Desc   String   @default("")
  visionFeature2Icon   String   @default("")
  visionFeature2Title  String   @default("")
  visionFeature2Desc   String   @default("")
  visionFeature3Icon   String   @default("")
  visionFeature3Title  String   @default("")
  visionFeature3Desc   String   @default("")
  missionTitle         String   @default("")
  missionDesc          String   @default("")
  missionImage1        String   @default("")
  missionImage2        String   @default("")
  missionImage3        String   @default("")
  missionFeature1Icon  String   @default("")
  missionFeature1Title String   @default("")
  missionFeature1Desc  String   @default("")
  missionFeature2Icon  String   @default("")
  missionFeature2Title String   @default("")
  missionFeature2Desc  String   @default("")
  missionFeature3Icon  String   @default("")
  missionFeature3Title String   @default("")
  missionFeature3Desc  String   @default("")
  updatedAt            DateTime @updatedAt

  @@map("mission_vision")
}

model Gallery {
  id           Int      @id @default(autoincrement())
  title        String
  type         String
  mediaUrl     String
  thumbnailUrl String?
  status       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("gallery")
}

model Admission {
  id             Int                  @id @default(autoincrement())
  studentId      String               @unique
  enquiryId      Int?                 @unique
  enquiry        Enquiry?             @relation(fields: [enquiryId], references: [id])
  firstName      String
  surname        String
  email          String?
  mobile         String
  courseName     String
  courseType     String
  courseFee      Float?
  discountType   String?
  discountValue  Float?
  isGstTaken     Boolean              @default(false)
  gstAmount      Float?
  finalAmount    Float?
  admissionFee   Float?
  admissionDate  String
  showFatherName Boolean              @default(true)
  showSurname    Boolean              @default(true)
  batch          String?
  referralBy     String?
  status         String               @default("Active")
  installments   PaymentInstallment[]
  attendance     StudentAttendance[]
  examResults    ExamResult[]
  certificates   Certificate[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@map("admissions")
}

model PaymentInstallment {
  id            Int       @id @default(autoincrement())
  admissionId   Int
  admission     Admission @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  installmentNo Int
  amount        Float
  paidAmount    Float     @default(0)
  dueDate       DateTime
  paidDate      DateTime?
  paymentMethod String?
  transactionId String?
  lateFee       Float     @default(0)
  frequency     String    @default("Monthly")
  status        String    @default("Pending") // Pending, Paid, Partially Paid
  invoiceUrl    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("payment_installments")
}

model Language {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("languages")
}

model StaffAttendance {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  teacherId Int?
  teacher   Teacher? @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  date      String
  status    String // Present, Absent, Late, Half Day
  remarks   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("staff_attendance")
}

model AttendanceSettings {
  id          Int      @id @default(1)
  weekOffDays String[] @default(["Saturday", "Sunday"])
  updatedAt   DateTime @updatedAt

  @@map("attendance_settings")
}

model StaffLeave {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromDate  String
  toDate    String
  type      String // Casual, Sick, etc.
  reason    String?
  status    String   @default("Pending") // Pending, Approved, Rejected
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("staff_leaves")
}

model StaffLecture {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String
  topic     String
  batch     String?
  duration  String? // e.g., "1 hour"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("staff_lectures")
}

model StaffSalaryRecord {
  id             Int      @id @default(autoincrement())
  userId         Int?
  user           User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  teacherId      Int?
  teacher        Teacher? @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  month          String
  year           String
  basicSalary    Float    @default(0)
  grossSalary    Float
  deductions     Float    @default(0)
  netSalary      Float
  totalDays      Int      @default(0)
  presentCount   Float    @default(0)
  absentCount    Float    @default(0)
  halfDayCount   Float    @default(0)
  lateCount      Float    @default(0)
  calculatedDays Float    @default(0)
  status         String   @default("Paid") // Paid, Unpaid
  paidDate       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("staff_salary_records")
}

model BackgroundImage {
  id             Int      @id @default(autoincrement())
  title          String   @unique
  imageUrl       String   @default("")
  type           String   @default("PORTRAIT")
  designSettings Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("background_images")
}

model Subject {
  id             Int             @id @default(autoincrement())
  name           String          @unique
  totalQuestions Int             @default(0)
  status         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  questionBanks  QuestionBank[]
  questions      Question[]
  courseSubjects CourseSubject[]
  videos         CourseVideo[]
  notes          CourseNote[]

  @@map("subjects")
}

model QuestionBank {
  id            Int      @id @default(autoincrement())
  subjectId     Int
  subject       Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  language      String
  examType      String // e.g., "Final Exam", "Mock Test", "Both"
  fileUrl       String
  questionCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("question_banks")
}

model Question {
  id        Int      @id @default(autoincrement())
  subjectId Int
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  text      String
  imageUrl  String?
  language  String   @default("english")
  examType  String   @default("Both") // "Mock Test", "Final Exam", "Both"
  optionA   String
  optionB   String
  optionC   String
  optionD   String
  answer    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("questions")
}

model TopPerformer {
  id          Int      @id @default(autoincrement())
  name        String
  image       String   @default("")
  course      String   @default("")
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("top_performers")
}

model TopPerformerSettings {
  id          Int      @id @default(1)
  title       String   @default("Unmatched Performance Excellence")
  description String   @default("Delivering exceptional results through cutting-edge solutions and proven methodologies")
  bannerUrl   String   @default("")
  updatedAt   DateTime @updatedAt

  @@map("top_performer_settings")
}

model ExamResult {
  id           Int       @id @default(autoincrement())
  admissionId  Int
  admission    Admission @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  semesterName String    @default("First Semester")

  totalObjectiveMarks    Float @default(0)
  obtainedObjectiveMarks Float @default(0)
  totalPracticalMarks    Float @default(0)
  obtainedPracticalMarks Float @default(0)

  totalMarks    Float         @default(0)
  obtainedMarks Float         @default(0)
  percentage    Float         @default(0)
  result        String        @default("Fail")
  grade         String        @default("N/A")
  subjects      String?
  isConfirmed   Boolean       @default(false)
  certificates  Certificate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("exam_results")
}

model Certificate {
  id            Int        @id @default(autoincrement())
  admissionId   Int
  admission     Admission  @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  examResultId  Int
  examResult    ExamResult @relation(fields: [examResultId], references: [id], onDelete: Cascade)
  status        String     @default("Requested") // Requested, Approved, Rejected
  issuedDate    DateTime?
  certificateNo String?    @unique
  remarks       String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@map("certificates")
}

model Notification {
  id        Int      @id @default(autoincrement())
  title     String
  message   String
  type      String   @default("info") // info, enquiry, admission, certificate
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notifications")
}

model FranchiseRequest {
  id              Int      @id @default(autoincrement())
  institutionName String
  ownerName       String
  designation     String
  dob             String
  email           String
  mobile          String
  fullAddress     String
  taluka          String
  pincode         String
  city            String
  state           String
  computers       String
  staff           String
  status          String   @default("Pending") // Pending, Approved, Rejected
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("franchise_requests")
}

model StudyMaterial {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  fileUrl     String
  status      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("study_materials")
}

model ContactSettings {
  id        Int      @id @default(1)
  title     String   @default("Histudy Course Contact can join with us")
  phone1    String   @default("")
  phone2    String   @default("")
  whatsapp  String   @default("")
  email1    String   @default("")
  email2    String   @default("")
  address   String   @default("")
  mapIframe String   @default("")
  updatedAt DateTime @updatedAt

  @@map("contact_settings")
}

model SampleCertificate {
  id        Int      @id @default(autoincrement())
  name      String
  image     String
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sample_certificates")
}

model Affiliation {
  id        Int      @id @default(autoincrement())
  title     String
  subtitle  String?
  image     String
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("affiliations")
}

model Post {
  id               Int      @id @default(autoincrement())
  title            String
  subheading       String
  thumbnail        String
  description      String
  additionalImages String[] @default([])
  tags             String[] @default([])
  status           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("posts")
}

model Job {
  id               Int      @id @default(autoincrement())
  title            String
  location         String
  jobType          String   @default("Full-time")
  description      String
  requirements     String[] @default([])
  responsibilities String[] @default([])
  salaryRange      String?
  status           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  applications JobApplication[]

  @@map("jobs")
}

model JobApplication {
  id          Int      @id @default(autoincrement())
  jobId       Int
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  fullName    String
  email       String
  mobile      String
  experience  String?
  skills      String?
  coverLetter String?
  status      String   @default("Pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("job_applications")
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  date        String
  time        String?
  location    String?
  description String
  image       String?
  status      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("events")
}

model WebsiteSlide {
  id        Int      @id @default(autoincrement())
  title     String   @default("")
  subtitle  String   @default("")
  link      String   @default("")
  imageUrl  String   @default("")
  order     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("website_slides")
}

model Partner {
  id        Int      @id @default(autoincrement())
  name      String   @default("")
  imageUrl  String   @default("")
  link      String?  @default("")
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("partners")
}

model OnlineClass {
  id        Int      @id @default(autoincrement())
  title     String   @default("")
  date      String   @default("")
  time      String   @default("")
  link      String   @default("")
  courseId  Int
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("online_classes")
}

model PaymentDetail {
  id   Int    @id @default(autoincrement())
  type String // BankAccount, UPI, QRCode

  // Bank Details
  accountHolderName String?
  bankName          String?
  accountNumber     String?
  ifscCode          String?
  branchName        String?

  // UPI Details
  upiId String?

  // QR Details
  qrImageUrl String?

  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payment_details")
}

model PaymentGatewaySetting {
  id             Int      @id @default(1)
  isActive       Boolean  @default(false)
  isTestMode     Boolean  @default(true)
  razorpayApiKey String   @default("")
  razorpaySecret String   @default("")
  companyName    String   @default("")
  updatedAt      DateTime @updatedAt

  @@map("payment_gateway_settings")
}

model StudentLeave {
  id           Int      @id @default(autoincrement())
  studentName  String
  studentEmail String?
  startDate    String
  endDate      String
  type         String   @default("Sick Leave")
  reason       String?
  status       String   @default("Pending")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("student_leaves")
}

model ExpenseType {
  id        Int              @id @default(autoincrement())
  name      String           @unique
  status    Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  subTypes  ExpenseSubType[]
  expenses  Expense[]

  @@map("expense_types")
}

model ExpenseSubType {
  id            Int         @id @default(autoincrement())
  expenseTypeId Int
  expenseType   ExpenseType @relation(fields: [expenseTypeId], references: [id], onDelete: Cascade)
  name          String
  status        Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  expenses      Expense[]

  @@unique([expenseTypeId, name])
  @@map("expense_sub_types")
}

model Expense {
  id               Int     @id @default(autoincrement())
  receiptNo        String  @unique
  expenseTypeId    Int
  expenseSubTypeId Int
  receiverName     String?
  issuePersonName  String?
  amount           Float
  paymentMode      String
  date             String
  remark           String?

  expenseType    ExpenseType    @relation(fields: [expenseTypeId], references: [id], onDelete: Cascade)
  expenseSubType ExpenseSubType @relation(fields: [expenseSubTypeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("expenses")
}

model InventoryCategory {
  id        Int                @id @default(autoincrement())
  name      String             @unique
  status    Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  products  InventoryProduct[]

  @@map("inventory_categories")
}

model InventoryProduct {
  id         Int               @id @default(autoincrement())
  categoryId Int
  category   InventoryCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name       String            @unique
  mrp        Float
  price      Float
  quantity   Int               @default(0)
  stockDate  String?
  imageUrl   String?
  status     Boolean           @default(true)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@map("inventory_products")
}
